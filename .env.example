# ==============================
# Avocado 生产环境环境变量模板
# 请复制一份为 .env 并在 Docker 部署前修改配置项
# ==============================

# PostgreSQL 数据库配置
POSTGRES_USER=root
POSTGRES_PASSWORD=password
POSTGRES_DB=avocado

# API 服务暴露的基础URL，用于生成各类 Webhook 调用或图片地址的完整链接
API_BASE_URL=http://localhost:3000

# 生产环境请更换更加安全的 JWT 密钥
JWT_SECRET=super-secret-key-change-me
